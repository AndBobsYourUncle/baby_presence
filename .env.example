RTSP_URL=rtsp://user:pass@camera.local:554/stream
MQTT_HOST=mqtt.local
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=

# Optional tuning
# CONFIDENCE=0.25
# SAMPLE_INTERVAL=2.0
# DEBOUNCE_SECONDS=15.0
# MODEL_PATH=yolov8n.pt

# Optional: save one frame per interval for later fine-tuning
# FRAME_LOG_DIR=/var/lib/baby_presence/frames
# FRAME_LOG_INTERVAL=60.0

# Optional HA/MQTT tweaks
# BASE_TOPIC=babypresence
# HA_DISCOVERY_PREFIX=homeassistant
# DEVICE_ID=baby_presence_crib
# DEVICE_NAME=Baby Crib
# MQTT_CLIENT_ID=baby_presence
# LOG_LEVEL=INFO
